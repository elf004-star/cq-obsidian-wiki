# ============================================================
# Obsidian Vault — .gitignore
#cq-obsidian-wiki
# ============================================================

# --- Obsidian config & state ---
.obsidian/
.obsidian.json
.obsidian.plugins.json
workspace-mobile.json

# --- System files ---
.DS_Store
Thumbs.db
desktop.ini
._*

# --- Temp & swap files ---
*.tmp
*.temp
*.swp
*.swo
*~
.*.swp
.*.swo
*.bak
*.orig

# --- OS caches ---
.__MACOSX/
.AppleDouble
.LSStore
ehthumbs.db
Icon?
ehthumbs.db
Session.vim

# --- Python ---
__pycache__/
*.py[cod]
*.pyc
venv/
.venv/
env/
.env.local
.env.*.local
*.egg-info/
dist/
build/
*.egg
.eggs/
*.manifest
*.spec

# --- Node / npm ---
node_modules/
package-lock.json
yarn.lock
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE ---
.vscode/
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
*.sublime-*

# --- Image caches (Obsidian image auto生成) ---
assets/
# 若 assets/ 放的是手动上传的图片，取消上方注释，保留版本控制
# 若 assets/ 全是自动生成的缓存图片，注释掉此行

# --- Log & archive files ---
log-*.md
_archive/
_archive/**/*

# --- Local-only secrets (API keys, tokens) ---
.env
.secrets/
*.pem
*.key

# --- Large binary files (音频/视频) ---
*.mp3
*.mp4
*.wav
*.mov
*.avi
*.zip
*.tar
*.gz
*.rar
*.7z

# --- Obsidian plugins (可选择) ---
plugins/
# 如需保留插件配置，注释掉此行
